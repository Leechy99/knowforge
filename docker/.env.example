# Docker Compose Environment Variables Template
# Copy this file to .env and fill in your values

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai-kb-consumers
KAFKA_DLQ_TOPIC=dlq-events

# PostgreSQL
POSTGRES_DSN=postgresql+asyncpg://aikb:aikb_secret@localhost:5432/aikb

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=ai_knowledge_base

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=aikb
MINIO_SECRET_KEY=aikb_secret
MINIO_BUCKET_NAME=knowforge

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_LOG_LEVEL=INFO

# Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
HEALTH_CHECK_TIMEOUT_SECONDS=2.0

# Content Extraction
MAX_FILE_SIZE=104857600  # 100MB
SUPPORTED_EXTENSIONS=pdf,docx,txt,md,html,csv,json
