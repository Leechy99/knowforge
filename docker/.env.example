# Docker Compose Environment Variables Template
# Copy this file to .env and fill in your values

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DOCUMENTS=documents
KAFKA_TOPIC_EVENTS=events
KAFKA_CONSUMER_GROUP=aikb-consumer-group

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aikb
POSTGRES_USER=aikb
POSTGRES_PASSWORD=aikb_secret

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=documents

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=aikb
S3_SECRET_KEY=aikb_secret
S3_BUCKET_NAME=aikb-documents
S3_REGION=us-east-1

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_LOG_LEVEL=INFO

# Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Content Extraction
MAX_FILE_SIZE=104857600  # 100MB
SUPPORTED_EXTENSIONS=pdf,docx,txt,md,html,csv,json